    {
      "name": "Create blacklist case duplicate email",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('duplicate email: status code is 412', function () {",
              "  pm.response.to.have.status(412);",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const domain = pm.variables.get('DOMAIN_URL'); // env/collection/global all supported",
              "const token = pm.variables.get('TOKEN');",
              "",
              "pm.test('DOMAIN_URL is set', () => pm.expect(domain, 'DOMAIN_URL').to.be.ok);",
              "pm.test('TOKEN is set', () => pm.expect(token, 'TOKEN').to.be.ok);",
              "",
              "const duplicateEmail = pm.variables.replaceIn('{{$randomEmail}}');",
              "pm.collectionVariables.set('duplicateEmail', duplicateEmail);",
              "",
              "const firstRequestBody = {",
              "  email: duplicateEmail,",
              "  app_uuid: '0054da1d-8682-482e-aa15-c79891c625a5',",
              "  blocked_reason: 'Spam'",
              "};",
              "",
              "const firstResponse = await new Promise((resolve, reject) => {",
              "  pm.sendRequest({",
              "    url: `http://${domain}/blacklists`,",
              "    method: 'POST',",
              "    header: {",
              "      'Content-Type': 'application/json',",
              "      'Authorization': `Bearer ${token}`",
              "    },",
              "    body: {",
              "      mode: 'raw',",
              "      raw: JSON.stringify(firstRequestBody)",
              "    }",
              "  }, (err, res) => err ? reject(err) : resolve(res));",
              "});",
              "",
              "console.log('First insert status:', firstResponse.code);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
